                    }

                    // Update bottom nav
                    document.querySelectorAll('.nav-item').forEach(el => {
                        el.classList.toggle('active', el.dataset.view === viewId);
                    });

                    // View-specific initialization
                    if (viewId === 'home') renderHome();
                    if (viewId === 'categories') renderCategories();
                    if (viewId === 'cart') renderCart();
                    if (viewId === 'orders') renderOrders();
                    if (viewId === 'wallet') renderWallet();
                    if (viewId === 'product' && params) renderProductDetail(params);
                    if (viewId === 'tracking' && params) renderTracking(params);

                    window.scrollTo(0, 0);
                    saveState();
                }
            },
            back: () => {
                if (appState.viewHistory.length > 1) {
                    appState.viewHistory.pop();
                    const prevView = appState.viewHistory[appState.viewHistory.length - 1];
                    router.navigate(prevView);
                } else {
                    router.navigate('home');
                }
            }
        };

        // --- 4. UI RENDERING FUNCTIONS ---
        function renderHome() {
            // Render Categories
            const catContainer = document.getElementById('categories-container');
            catContainer.innerHTML = DB.categories.map(cat => `
                <div class="flex flex-col items-center gap-2 min-w-[72px] cursor-pointer" onclick="router.navigate('categories')">
                    <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-3xl shadow-sm" style="background-color: ${cat.color}">
                        ${cat.icon}
                    </div>
                    <span class="text-xs font-medium text-center text-secondary">${cat.name}</span>
                </div>
            `).join('');

            // Render Essentials Grid
            const essentials = DB.products.slice(0, 4);
            document.getElementById('essentials-grid').innerHTML = essentials.map(p => createProductCard(p)).join('');

            // Render Healthy Grid
            const healthy = DB.products.slice(4, 8);
            document.getElementById('healthy-grid').innerHTML = healthy.map(p => createProductCard(p)).join('');
        }

        function createProductCard(product) {
            const discount = Math.round(((product.originalPrice - product.price) / product.originalPrice) * 100);
            return `
                <div class="product-card" onclick="router.navigate('product', '${product.id}')">
                    <div class="product-image-wrapper">
                        <img src="${product.image}" alt="${product.name}" class="product-image" loading="lazy">
                        ${discount > 0 ? `<span class="product-badge badge badge-success">${discount}% OFF</span>` : ''}
                    </div>
                    <div class="product-info">
                        <div class="product-title line-clamp-2">${product.name}</div>
                        <div class="product-meta">${product.weight} · ⭐ ${product.rating}</div>
                        <div class="product-footer">
                            <div>
                                <span class="product-price">₹${product.price}</span>
                                ${discount > 0 ? `<span class="product-price-original">₹${product.originalPrice}</span>` : ''}
                            </div>
                            <button class="btn-add-cart" onclick="event.stopPropagation(); addToCart('${product.id}')">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                            </button>
                        </div>
                    </div>
                </div>
            `;
        }

        function renderCategories() {
            const grid = document.getElementById('all-categories-grid');
            grid.innerHTML = DB.categories.map(cat => `
                <div class="card card-interactive p-4 flex items-center gap-4" onclick="alert('Filtering by ${cat.name}')">
                    <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl" style="background-color: ${cat.color}">
                        ${cat.icon}
                    </div>
                    <div class="font-semibold">${cat.name}</div>
                </div>
            `).join('');
        }

        function renderProductDetail(productId) {
            const product = DB.products.find(p => p.id === productId);
            if (!product) return;

            document.getElementById('product-detail-image').src = product.image;
            document.getElementById('product-detail-category').textContent = product.category;
            document.getElementById('product-detail-name').textContent = product.name;
            document.getElementById('product-detail-weight').textContent = product.weight;
            document.getElementById('product-detail-price').textContent = `₹${product.price}`;
            document.getElementById('product-detail-original').textContent = `₹${product.originalPrice}`;
            document.getElementById('product-detail-desc').textContent = product.desc;

            const btn = document.getElementById('product-add-btn');
            btn.onclick = () => {
                addToCart(product.id);
                // Visual feedback
                btn.innerHTML = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Added`;
                btn.style.background = 'var(--color-success)';
                setTimeout(() => {
                    btn.innerHTML = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg> Add to Cart`;
                    btn.style.background = '';
                }, 1500);
            };
        }

        function renderCart() {
            const container = document.getElementById('cart-items-container');
            if (appState.cart.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-12">
                        <div class="text-6xl mb-4">🛒</div>
                        <h3 class="font-bold text-lg mb-2">Your cart is empty</h3>
                        <p class="text-muted mb-6">Looks like you haven't added anything yet.</p>
                        <button class="btn btn-primary" onclick="router.navigate('home')">Start Shopping</button>
                    </div>
                `;
                document.getElementById('cart-subtotal').textContent = '₹0';
                document.getElementById('cart-total').textContent = '₹0';
                return;
            }

            let subtotal = 0;
            container.innerHTML = appState.cart.map(item => {
                const product = DB.products.find(p => p.id === item.productId);
                const itemTotal = product.price * item.qty;
                subtotal += itemTotal;
                return `
                    <div class="card p-4 flex gap-4">
                        <img src="${product.image}" class="w-20 h-20 rounded-lg object-cover bg-gray-100">
                        <div class="flex-1 flex flex-col justify-between">
                            <div>
                                <div class="font-semibold line-clamp-1">${product.name}</div>
                                <div class="text-xs text-muted">${product.weight}</div>
                            </div>
                            <div class="flex justify-between items-center">
                                <div class="font-bold">₹${itemTotal}</div>
                                <div class="flex items-center gap-3 bg-gray-50 rounded-lg p-1">
                                    <button class="w-8 h-8 flex items-center justify-center rounded-md bg-white shadow-sm text-primary font-bold" onclick="updateCartQty('${item.productId}', -1)">-</button>
                                    <span class="font-semibold w-4 text-center">${item.qty}</span>
                                    <button class="w-8 h-8 flex items-center justify-center rounded-md bg-white shadow-sm text-primary font-bold" onclick="updateCartQty('${item.productId}', 1)">+</button>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');

            document.getElementById('cart-subtotal').textContent = `₹${subtotal}`;
            document.getElementById('cart-total').textContent = `₹${subtotal}`;
        }

        function renderOrders() {
            const container = document.getElementById('orders-list');
            // Mock orders + any live order
            const orders = [
                { id: 'ORD-9921', date: 'Today, 10:30 AM', status: 'Delivered', total: 145, items: 'Amul Milk, Brown Bread' },
                { id: 'ORD-8832', date: 'Yesterday, 6:15 PM', status: 'Delivered', total: 320, items: 'Organic Eggs, Paneer, Tomatoes' }
            ];
            
            // If there's a live order in global state, show it
            const globalState = JSON.parse(localStorage.getItem('lcos_state') || '{}');
            if (globalState.currentOrderId && globalState.orders) {
                const liveOrder = globalState.orders.find(o => o.id === globalState.currentOrderId);
                if (liveOrder) {
                    orders.unshift({ 
                        id: liveOrder.id, 
                        date: liveOrder.time, 
                        status: liveOrder.status === 'delivered' ? 'Delivered' : 'Live', 
                        total: liveOrder.price, 
                        items: liveOrder.product,
                        isLive: liveOrder.status !== 'delivered'
                    });
                }
            }

            container.innerHTML = orders.map(o => `
                <div class="card p-4 card-interactive" onclick="${o.isLive ? `router.navigate('tracking', '${o.id}')` : ''}">
                    <div class="flex justify-between items-start mb-2">
                        <div>
                            <div class="font-bold">${o.id}</div>
                            <div class="text-xs text-muted">${o.date}</div>
                        </div>
                        <span class="badge ${o.isLive ? 'badge-live' : 'badge-success'}">${o.status}</span>
                    </div>
                    <div class="text-sm text-secondary mb-3 line-clamp-1">${o.items}</div>
                    <div class="flex justify-between items-center pt-3 border-t">
                        <span class="font-bold">₹${o.total}</span>
                        <button class="btn btn-sm btn-outline">Reorder</button>
                    </div>
                </div>
            `).join('');
        }

        function renderWallet() {
            document.getElementById('wallet-balance').textContent = `₹${DB.user.walletBalance}`;
            const txContainer = document.getElementById('wallet-transactions');
            const txs = [
                { type: 'credit', amount: 50, desc: 'Cashback on order #ORD-9921', time: '10:30 AM' },
                { type: 'debit', amount: 145, desc: 'Payment for order #ORD-9921', time: '10:25 AM' },
                { type: 'credit', amount: 200, desc: 'Money added via UPI', time: 'Yesterday' }
            ];
            txContainer.innerHTML = txs.map(tx => `
                <div class="flex items-center justify-between p-3 bg-surface rounded-xl border">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full flex items-center justify-center ${tx.type === 'credit' ? 'bg-success-bg text-success' : 'bg-gray-100 text-gray-600'}">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                ${tx.type === 'credit' ? '<path d="M12 19V5M5 12l7-7 7 7"/>' : '<path d="M12 5v14M19 12l-7 7-7-7"/>'}
                            </svg>
                        </div>
                        <div>
                            <div class="font-semibold text-sm">${tx.desc}</div>
                            <div class="text-xs text-muted">${tx.time}</div>
                        </div>
                    </div>
                    <div class="font-bold ${tx.type === 'credit' ? 'text-success' : 'text-text'}">
                        ${tx.type === 'credit' ? '+' : '-'}₹${tx.amount}
                    </div>
                </div>
            `).join('');
        }

        function renderTracking(orderId) {
            document.getElementById('tracking-order-id').textContent = orderId;
            
            // Simulate progress
            let progress = 0;
            const progressBar = document.getElementById('tracking-progress');
            const marker = document.getElementById('rider-marker');
            const eta = document.getElementById('tracking-eta');
            
            const interval = setInterval(() => {
                progress += 2;
                if (progress > 90) progress = 90;
                
                progressBar.style.width = `${progress}%`;
                marker.style.left = `${10 + (progress * 0.8)}%`;
                
                const mins = Math.max(1, Math.round(10 - (progress / 10)));
                eta.textContent = `${mins} min${mins > 1 ? 's' : ''}`;
                
                if (progress >= 90) clearInterval(interval);
            }, 500);

            // Timeline
            const timeline = document.getElementById('tracking-timeline');
            const steps = [
                { status: 'Order Placed', time: '10:30 AM', done: true },
                { status: 'Order Accepted by Store', time: '10:31 AM', done: true },
                { status: 'Packed & Ready', time: '10:35 AM', done: true },
                { status: 'Rider Assigned', time: '10:37 AM', done: true },
                { status: 'Out for Delivery', time: '10:40 AM', done: true, active: true },
                { status: 'Delivered', time: 'Expected 10:48 AM', done: false }
            ];
            
            timeline.innerHTML = steps.map(step => `
                <div class="relative">
                    <div class="absolute -left-[31px] w-4 h-4 rounded-full border-2 ${step.done ? 'bg-primary border-primary' : (step.active ? 'bg-white border-primary animate-pulse' : 'bg-gray-200 border-gray-300')}"></div>
                    <div class="${step.done || step.active ? 'text-text' : 'text-muted'}">
                        <div class="font-semibold text-sm">${step.status}</div>
                        <div class="text-xs">${step.time}</div>
                    </div>
                </div>
            `).join('');
        }

        // --- 5. CART LOGIC ---
        function addToCart(productId) {
            const existing = appState.cart.find(item => item.productId === productId);
            if (existing) {
                existing.qty++;
            } else {
                appState.cart.push({ productId, qty: 1 });
            }
            saveState();
            showCartBar();
        }

        function updateCartQty(productId, delta) {
            const item = appState.cart.find(i => i.productId === productId);
            if (!item) return;
            
            item.qty += delta;
            if (item.qty <= 0) {
                appState.cart = appState.cart.filter(i => i.productId !== productId);
            }
            saveState();
            renderCart(); // Re-render if on cart page
        }

        function updateCartUI() {
            const totalItems = appState.cart.reduce((sum, item) => sum + item.qty, 0);
            const totalPrice = appState.cart.reduce((sum, item) => {
                const p = DB.products.find(prod => prod.id === item.productId);
                return sum + (p ? p.price * item.qty : 0);
            }, 0);

            // Update Badge
            const badge = document.getElementById('nav-cart-badge');
            if (totalItems > 0) {
                badge.textContent = totalItems;
                badge.classList.remove('hidden');
            } else {
                badge.classList.add('hidden');
            }

            // Update Bottom Bar
            document.getElementById('cart-count').textContent = totalItems;
            document.getElementById('cart-bar-total').textContent = `₹${totalPrice}`;
            
            if (totalItems > 0) {
                document.getElementById('cart-bar').classList.add('visible');
            } else {
                document.getElementById('cart-bar').classList.remove('visible');
            }
        }

        function showCartBar() {
            // Trigger animation
            const bar = document.getElementById('cart-bar');
            bar.classList.add('visible');
            setTimeout(() => {
                if (appState.cart.reduce((sum, item) => sum + item.qty, 0) === 0) {
                    bar.classList.remove('visible');
                }
            }, 3000);
        }

        // --- 6. CHECKOUT & ORDER SIMULATION ---
        function placeDemoOrder() {
            if (appState.cart.length === 0) return;
            
            const total = appState.cart.reduce((sum, item) => {
                const p = DB.products.find(prod => prod.id === item.productId);
                return sum + (p ? p.price * item.qty : 0);
            }, 0);
            
            const productName = appState.cart.length === 1 ? DB.products.find(p => p.id === appState.cart[0].productId).name : `${appState.cart.length} items`;
            
            // Call global state simulation (from state.js logic)
            if (typeof window.placeOrder === 'function') {
                window.placeOrder(productName, total);
                window.simulateFullLifecycle();
            }
            
            // Clear cart
            appState.cart = [];
            saveState();
            
            // Navigate to tracking
            setTimeout(() => {
                const globalState = JSON.parse(localStorage.getItem('lcos_state') || '{}');
                if (globalState.currentOrderId) {
                    router.navigate('tracking', globalState.currentOrderId);
                } else {
                    router.navigate('orders');
                }
            }, 500);
        }

        // --- 7. SEARCH LOGIC ---
        function handleSearch(query) {
            const container = document.getElementById('search-results');
            if (!query.trim()) {
                container.innerHTML = '<div class="text-center text-muted py-8">Start typing to search products...</div>';
                return;
            }
            
            const results = DB.products.filter(p => 
                p.name.toLowerCase().includes(query.toLowerCase()) || 
                p.category.toLowerCase().includes(query.toLowerCase())
            );
            
            if (results.length === 0) {
                container.innerHTML = '<div class="text-center text-muted py-8">No products found.</div>';
            } else {
                container.innerHTML = `<div class="product-grid" style="grid-template-columns: 1fr; padding: 0;">${results.map(p => createProductCard(p)).join('')}</div>`;
            }
        }

        // --- 8. AI CHAT LOGIC ---
        function sendChatMessage() {
            const input = document.getElementById('chat-input');
            const message = input.value.trim();
            if (!message) return;
            
            const container = document.getElementById('chat-messages');
            
            // Add user message
            container.innerHTML += `<div class="chat-message user">${message}</div>`;
            input.value = '';
            container.scrollTop = container.scrollHeight;
            
            // Simulate AI typing
            setTimeout(() => {
                const responses = [
                    "I've added those items to your cart! Would you like me to apply the 'SAVE10' coupon for you?",
                    "Based on your previous orders, I recommend trying the new Organic Eggs. They are currently 10% off!",
                    "I can help you plan a healthy weekly meal. Would you like me to generate a shopping list for 7 days?",
                    "Your order is currently out for delivery and should arrive in approximately 8 minutes."
                ];
                const randomResponse = responses[Math.floor(Math.random() * responses.length)];
                container.innerHTML += `<div class="chat-message ai">${randomResponse}</div>`;
                container.scrollTop = container.scrollHeight;
            }, 1000);
        }

        // --- 9. INITIALIZATION ---
        document.addEventListener('DOMContentLoaded', () => {
            renderHome();
            updateCartUI();
            
            // Listen for global state changes (from other tabs)
            if (typeof window.channel !== 'undefined') {
                window.channel.onmessage = () => {
                    if (appState.currentView === 'orders') renderOrders();
                    if (appState.currentView === 'tracking') {
                        const gs = JSON.parse(localStorage.getItem('lcos_state') || '{}');
                        if (gs.currentOrderId) renderTracking(gs.currentOrderId);
                    }
                };
            }
        });

    </script>
    <script src="./state.js"></script>
</body>
</html>
