    <script>
        /**
         * LOCAL COMMERCE OS - RIDER APP CONTROLLER
         * Handles UI rendering, delivery lifecycle, map simulation, and real-time sync.
         */

        // --- 1. MOCK DATA (Rider Specific) ---
        const riderDB = {
            leaderboard: [
                { name: 'Arjun Singh', deliveries: 32, earnings: 4500, rank: 1 },
                { name: 'Priya Sharma', deliveries: 29, earnings: 4100, rank: 2 },
                { name: 'Rahul Verma', deliveries: 27, earnings: 3800, rank: 3 },
                { name: 'You (Rider)', deliveries: 25, earnings: 3240, rank: 4, isUser: true },
                { name: 'Amit Patel', deliveries: 22, earnings: 2900, rank: 5 },
                { name: 'Sneha Reddy', deliveries: 20, earnings: 2750, rank: 6 },
            ],
            transactions: [
                { id: 'TXN-R-001', desc: 'Delivery #ORD9921', amount: 45, type: 'credit', time: '10:45 AM' },
                { id: 'TXN-R-002', desc: 'Tip from Nitish Kumar', amount: 10, type: 'credit', time: '10:45 AM' },
                { id: 'TXN-R-003', desc: 'Delivery #ORD8832', amount: 50, type: 'credit', time: '09:30 AM' },
                { id: 'TXN-R-004', desc: 'Withdrawal to Bank', amount: -1000, type: 'debit', time: 'Yesterday' },
                { id: 'TXN-R-005', desc: 'Surge Bonus (Rain)', amount: 150, type: 'credit', time: 'Yesterday' },
            ]
        };

        // --- 2. STATE & LIFECYCLE MANAGEMENT ---
        let isOnline = true;
        let currentDeliveryState = 'idle'; // idle, requested, picked_up, delivering, completed
        let requestTimerInterval = null;
        let mapAnimationInterval = null;

        function initRiderState() {
            // Ensure global state exists
            if (!window.state) {
                window.state = JSON.parse(localStorage.getItem('lcos_state')) || {
                    orders: [], currentOrderId: null, riderAssigned: null, stats: {}, wallet: { riderBalance: 450 }
                };
            }

            // Listen for BroadcastChannel messages
            if (typeof window.channel !== 'undefined') {
                window.channel.onmessage = (event) => {
                    window.state = event.data;
                    checkForNewRequests(window.state);
                    updateUI(window.state);
                };
            } else {
                // Fallback polling
                setInterval(() => {
                    const stored = JSON.parse(localStorage.getItem('lcos_state'));
                    if (stored && JSON.stringify(stored) !== JSON.stringify(window.state)) {
                        window.state = stored;
                        checkForNewRequests(window.state);
                        updateUI(window.state);
                    }
                }, 1000);
            }

            // Initial render
            updateUI(window.state);
            renderLeaderboard();
            renderTransactions();
        }

        function checkForNewRequests(state) {
            // If an order is assigned to a rider, and we are online, show the request sheet
            if (isOnline && state.riderAssigned && currentDeliveryState === 'idle') {
                const order = state.orders.find(o => o.id === state.riderAssigned);
                if (order && order.status === 'assigned') {
                    showNewOrderRequest(order);
                }
            }
            
            // If order is delivered, reset state
            if (state.riderAssigned) {
                const order = state.orders.find(o => o.id === state.riderAssigned);
                if (order && order.status === 'delivered' && currentDeliveryState !== 'completed') {
                    completeDelivery();
                }
            }
        }

        // --- 3. UI UPDATE ENGINE ---
        function updateUI(state) {
            // Update wallet balance
            document.getElementById('wallet-balance').textContent = `₹${state.wallet?.riderBalance || 450}`;
            
            // Update active badge
            const hasActiveOrder = state.riderAssigned && currentDeliveryState !== 'idle' && currentDeliveryState !== 'completed';
            const badge = document.getElementById('nav-active-badge');
            if (hasActiveOrder) {
                badge.classList.remove('hidden');
            } else {
                badge.classList.add('hidden');
            }
        }

        // --- 4. DELIVERY LIFECYCLE ACTIONS ---
        function showNewOrderRequest(order) {
            currentDeliveryState = 'requested';
            document.getElementById('req-order-id').textContent = order.id;
            
            // Show sheet
            document.getElementById('overlay').classList.add('active');
            document.getElementById('sheet-new-order').classList.add('active');
            
            // Start timer
            let timeLeft = 30;
            const timerEl = document.getElementById('request-timer');
            timerEl.textContent = timeLeft;
            
            clearInterval(requestTimerInterval);
            requestTimerInterval = setInterval(() => {
                timeLeft--;
                timerEl.textContent = timeLeft;
                if (timeLeft <= 0) {
                    clearInterval(requestTimerInterval);
                    rejectOrder();
                }
            }, 1000);
        }

        function acceptOrder() {
            clearInterval(requestTimerInterval);
            closeAllSheets();
            currentDeliveryState = 'picked_up'; // Simplified for demo
            
            // Update global state
            if (typeof window.riderAcceptOrder === 'function') {
                window.riderAcceptOrder();
            }
            
            // Switch to active view
            router.navigate('active');
            startMapAnimation();
            
            // Update action button
            document.getElementById('action-btn').innerHTML = `
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"></path></svg>
                Arrived at Customer
            `;
        }

        function rejectOrder() {
            clearInterval(requestTimerInterval);
            closeAllSheets();
            currentDeliveryState = 'idle';
            
            // Optional: notify state that rider rejected (not implemented in basic state.js, but good for UX)
        }

        function handleDeliveryAction() {
            const btn = document.getElementById('action-btn');
            if (currentDeliveryState === 'picked_up') {
                // Simulate arriving at customer
                currentDeliveryState = 'delivering';
                btn.innerHTML = `
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                    Enter OTP to Complete
                `;
                btn.onclick = () => {
                    document.getElementById('overlay').classList.add('active');
                    document.getElementById('sheet-otp').classList.add('active');
                    document.getElementById('otp-1').focus();
                };
            }
        }

        function verifyOTP() {
            const otp = ['otp-1', 'otp-2', 'otp-3', 'otp-4'].map(id => document.getElementById(id).value).join('');
            if (otp === '1234' || otp.length === 4) { // Accept any 4 digits for demo ease, or strictly 1234
                closeAllSheets();
                completeDelivery();
            } else {
                document.querySelector('.otp-input-group').classList.add('animate-shake');
                setTimeout(() => document.querySelector('.otp-input-group').classList.remove('animate-shake'), 600);
            }
        }

        function completeDelivery() {
            currentDeliveryState = 'completed';
            
            // Show success feedback
            const btn = document.getElementById('action-btn');
            btn.innerHTML = `✅ Delivery Completed`;
            btn.disabled = true;
            btn.classList.remove('btn-primary');
            btn.classList.add('btn-success');
            
            // Clear map animation
            clearInterval(mapAnimationInterval);
            
            // Reset to idle after a moment
            setTimeout(() => {
                currentDeliveryState = 'idle';
                btn.disabled = false;
                btn.classList.remove('btn-success');
                btn.classList.add('btn-primary');
                btn.innerHTML = `
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"></path></svg>
                    Arrived at Store
                `;
                btn.onclick = handleDeliveryAction;
                router.navigate('home');
            }, 3000);
        }

        // --- 5. MAP ANIMATION ---
        function startMapAnimation() {
            const marker = document.getElementById('rider-marker');
            const progress = document.getElementById('route-progress');
            let pos = 15; // Start at 15%
            
            clearInterval(mapAnimationInterval);
            mapAnimationInterval = setInterval(() => {
                pos += 1;
                if (pos > 85) pos = 85; // Stop at customer
                
                marker.style.left = `${pos}%`;
                progress.style.width = `${((pos - 15) / 70) * 100}%`;
            }, 500);
        }

        // --- 6. UI RENDERING (Leaderboard & Transactions) ---
        function renderLeaderboard() {
            const container = document.getElementById('leaderboard-list');
            container.innerHTML = riderDB.leaderboard.map(user => {
                let rankClass = 'rank-default';
                if (user.rank === 1) rankClass = 'rank-1';
                else if (user.rank === 2) rankClass = 'rank-2';
                else if (user.rank === 3) rankClass = 'rank-3';
                
                return `
                    <div class="leaderboard-item ${user.isUser ? 'bg-primary-50 -mx-4 px-4 rounded-xl border border-primary-100' : ''}">
                        <div class="rank-badge ${rankClass}">${user.rank}</div>
                        <div class="w-10 h-10 rounded-full bg-gray-200 overflow-hidden flex items-center justify-center font-bold text-gray-500">
                            ${user.name.charAt(0)}
                        </div>
                        <div class="flex-1">
                            <div class="font-bold text-sm ${user.isUser ? 'text-primary' : ''}">${user.name}</div>
                            <div class="text-xs text-muted">${user.deliveries} deliveries</div>
                        </div>
                        <div class="text-right">
                            <div class="font-bold text-sm">₹${user.earnings.toLocaleString()}</div>
                        </div>
                    </div>
                `;
            }).join('');
        }

        function renderTransactions() {
            const container = document.getElementById('transactions-list');
            container.innerHTML = riderDB.transactions.map(tx => `
                <div class="flex items-center justify-between p-3 bg-bg rounded-xl">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full flex items-center justify-center ${tx.type === 'credit' ? 'bg-success-bg text-success' : 'bg-danger-bg text-danger'}">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                ${tx.type === 'credit' ? '<path d="M12 19V5M5 12l7-7 7 7"/>' : '<path d="M12 5v14M19 12l-7 7-7-7"/>'}
                            </svg>
                        </div>
                        <div>
                            <div class="font-semibold text-sm">${tx.desc}</div>
                            <div class="text-xs text-muted">${tx.time}</div>
                        </div>
                    </div>
                    <div class="font-bold ${tx.type === 'credit' ? 'text-success' : 'text-danger'}">
                        ${tx.type === 'credit' ? '+' : ''}₹${tx.amount}
                    </div>
                </div>
            `).join('');
        }

        // --- 7. UTILITIES ---
        function toggleOnlineStatus() {
            isOnline = !isOnline;
            const toggle = document.getElementById('online-toggle');
            const dot = document.getElementById('status-dot');
            const text = document.getElementById('status-text');
            
            toggle.classList.toggle('active', isOnline);
            dot.classList.toggle('online', isOnline);
            dot.classList.toggle('offline', !isOnline);
            text.textContent = isOnline ? 'Online' : 'Offline';
        }

        function closeAllSheets() {
            document.getElementById('overlay').classList.remove('active');
            document.querySelectorAll('.bottom-sheet').forEach(sheet => sheet.classList.remove('active'));
        }

        function moveFocus(current, nextId) {
            if (current.value.length === 1) {
                document.getElementById(nextId)?.focus();
            }
        }

        // --- 8. ROUTER ---
        const router = {
            navigate: (viewId) => {
                document.querySelectorAll('.view').forEach(el => el.classList.remove('active'));
                document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
                
                const target = document.getElementById(`view-${viewId}`);
                if (target) {
                    target.classList.add('active');
                    document.querySelector(`.nav-item[data-view="${viewId}"]`)?.classList.add('active');
                    window.scrollTo(0, 0);
                }
            }
        };

        // --- 9. INITIALIZATION ---
        document.addEventListener('DOMContentLoaded', () => {
            initRiderState();
            
            // Expose router globally
            window.router = router;
        });
    </script>
</body>
</html>
