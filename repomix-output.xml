            to { opacity: 1; transform: translateY(0); }
        }

        /* --- 13. Components: Toast Notifications --- */
        .toast-container {
            position: fixed;
            top: 1.5rem;
            right: 1.5rem;
            z-index: 100;
            display: flex;
            flex-direction: column;
