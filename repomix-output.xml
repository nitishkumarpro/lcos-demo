            ],
            transactions: [
                { id: 'TXN-V-001', date: 'Today, 10:30 AM', desc: 'Order #ORD9921 Settlement', type: 'credit', amount: 110 },
                { id: 'TXN-V-002', date: 'Today, 09:15 AM', desc: 'Platform Commission (15%)', type: 'debit', amount: 45 },
                { id: 'TXN-V-003', date: 'Yesterday, 06:00 PM', desc: 'Order #ORD8832 Settlement', type: 'credit', amount: 280 },
                { id: 'TXN-V-004', date: 'Yesterday, 06:00 PM', desc: 'Platform Commission (15%)', type: 'debit', amount: 42 }
            ]
        };

        // --- 2. STATE SYNCHRONIZATION ---
        // We assume `state.js` is loaded globally, but we also set up a fallback listener
        // to ensure this tab reacts to changes from `customer.html`.
        
        function initVendorState() {
            // Ensure global state exists (in case state.js is loaded)
            if (!window.state) {
                window.state = JSON.parse(localStorage.getItem('lcos_state')) || {
                    orders: [],
                    stats: { totalOrders: 0, revenue: 0, liveOrders: 0 },
                    inventory: {}
                };
            }

            // Listen for BroadcastChannel messages
            if (typeof window.channel !== 'undefined') {
                window.channel.onmessage = (event) => {
                    window.state = event.data;
                    updateUI(window.state);
                };
            } else {
                // Fallback: Poll localStorage if BroadcastChannel fails (rare)
                setInterval(() => {
                    const stored = JSON.parse(localStorage.getItem('lcos_state'));
                    if (stored && JSON.stringify(stored) !== JSON.stringify(window.state)) {
                        window.state = stored;
                        updateUI(window.state);
                    }
                }, 1000);
            }

            // Initial render
            updateUI(window.state);
        }

        // --- 3. UI UPDATE ENGINE ---
        function updateUI(newState) {
            renderDashboardStats(newState);
            renderDashboardOrders(newState);
            renderPipeline(newState);
            renderInventory();
            renderProducts();
            renderFinance();
            updateSidebarBadge(newState);
        }

        function updateSidebarBadge(state) {
            const newOrders = state.orders.filter(o => o.status === 'placed' || o.status === 'accepted').length;
            const badge = document.getElementById('sidebar-order-badge');
            badge.textContent = newOrders;
            badge.classList.toggle('hidden', newOrders === 0);
        }

        function renderDashboardStats(state) {
            // Calculate today's revenue from state
            const todayRevenue = state.orders.reduce((sum, o) => sum + (o.price || 0), 0);
            document.getElementById('stat-revenue').textContent = `₹${todayRevenue.toLocaleString()}`;
            document.getElementById('stat-orders').textContent = state.stats.totalOrders || state.orders.length;
            
            // Low stock count
            const lowStockCount = vendorDB.products.filter(p => p.stock <= p.minStock).length;
            document.getElementById('stat-low-stock').textContent = lowStockCount;
        }

        function renderDashboardOrders(state) {
            const tbody = document.getElementById('dashboard-orders-table');
            const recentOrders = [...state.orders].reverse().slice(0, 5);
            
            if (recentOrders.length === 0) {
                tbody.innerHTML = `<tr><td colspan="6" class="text-center text-muted py-8">No orders yet. Share your store link!</td></tr>`;
                return;
            }

            tbody.innerHTML = recentOrders.map(order => {
                const statusBadge = getStatusBadge(order.status);
                let actionBtn = '';
                if (order.status === 'placed') {
                    actionBtn = `<button class="btn btn-sm btn-primary" onclick="advanceOrder('${order.id}', 'accepted')">Accept</button>`;
                } else if (order.status === 'accepted') {
                    actionBtn = `<button class="btn btn-sm btn-warning" onclick="advanceOrder('${order.id}', 'preparing')">Prep</button>`;
                } else if (order.status === 'preparing') {
                    actionBtn = `<button class="btn btn-sm btn-info" style="background:var(--color-info);color:white;" onclick="advanceOrder('${order.id}', 'packed')">Pack</button>`;
                } else {
                    actionBtn = `<span class="text-xs text-muted">Completed</span>`;
                }

                return `
                    <tr class="${order.status === 'placed' ? 'new-order' : ''}">
                        <td class="font-semibold">${order.id}</td>
                        <td>${order.customer}</td>
                        <td class="truncate" style="max-width: 150px;">${order.product}</td>
                        <td class="font-bold">₹${order.price}</td>
                        <td>${statusBadge}</td>
                        <td>${actionBtn}</td>
                    </tr>
                `;
            }).join('');
        }

        function renderPipeline(state) {
            const columns = {
                'placed': { el: document.getElementById('pipeline-new'), count: document.getElementById('count-new') },
                'accepted': { el: document.getElementById('pipeline-preparing'), count: document.getElementById('count-preparing') },
                'preparing': { el: document.getElementById('pipeline-preparing'), count: document.getElementById('count-preparing') }, // Grouped for demo
                'packed': { el: document.getElementById('pipeline-ready'), count: document.getElementById('count-ready') },
                'assigned': { el: document.getElementById('pipeline-ready'), count: document.getElementById('count-ready') },
                'delivered': { el: document.getElementById('pipeline-completed'), count: document.getElementById('count-completed') },
                'cancelled': { el: document.getElementById('pipeline-completed'), count: document.getElementById('count-completed') }
            };

            // Reset columns
            Object.values(columns).forEach(col => { col.el.innerHTML = ''; });
            const counts = { new: 0, preparing: 0, ready: 0, completed: 0 };

            state.orders.forEach(order => {
                let targetKey = order.status;
                if (targetKey === 'placed') { counts.new++; }
                else if (targetKey === 'accepted' || targetKey === 'preparing') { counts.preparing++; }
                else if (targetKey === 'packed' || targetKey === 'assigned') { counts.ready++; }
                else { counts.completed++; }

                const card = document.createElement('div');
                card.className = `pipeline-card ${order.status === 'placed' ? 'new-order' : ''}`;
                card.innerHTML = `
                    <div class="flex justify-between items-start mb-2">
                        <span class="font-bold text-sm">${order.id}</span>
                        <span class="text-xs text-muted">${order.time}</span>
                    </div>
                    <div class="text-sm mb-3 line-clamp-2">${order.product}</div>
                    <div class="flex justify-between items-center mb-3">
                        <span class="font-bold">₹${order.price}</span>
                        <span class="text-xs text-muted">${order.address}</span>
                    </div>
                    <div class="flex gap-2">
                        ${getPipelineActions(order)}
                    </div>
                `;
                
                // Map to correct column DOM element
                let colEl = columns['placed'].el;
                if (order.status === 'accepted' || order.status === 'preparing') colEl = columns['preparing'].el;
                else if (order.status === 'packed' || order.status === 'assigned') colEl = columns['packed'].el;
                else if (order.status === 'delivered' || order.status === 'cancelled') colEl = columns['delivered'].el;
                
                colEl.appendChild(card);
            });

            // Update counts
            document.getElementById('count-new').textContent = counts.new;
            document.getElementById('count-preparing').textContent = counts.preparing;
            document.getElementById('count-ready').textContent = counts.ready;
            document.getElementById('count-completed').textContent = counts.completed;
        }

        function getPipelineActions(order) {
            if (order.status === 'placed') {
                return `
                    <button class="btn btn-sm btn-primary w-full" onclick="advanceOrder('${order.id}', 'accepted')">Accept Order</button>
                    <button class="btn btn-sm btn-danger" onclick="advanceOrder('${order.id}', 'cancelled')">Reject</button>
                `;
            } else if (order.status === 'accepted' || order.status === 'preparing') {
                return `<button class="btn btn-sm btn-warning w-full" onclick="advanceOrder('${order.id}', 'packed')">Mark as Packed</button>`;
            } else if (order.status === 'packed' || order.status === 'assigned') {
                return `<button class="btn btn-sm btn-secondary w-full" disabled>Waiting for Rider...</button>`;
            }
            return `<span class="text-xs text-muted w-full text-center py-1">No actions needed</span>`;
        }

        function getStatusBadge(status) {
            const map = {
                'placed': '<span class="badge badge-primary">New</span>',
                'accepted': '<span class="badge badge-info">Accepted</span>',
                'preparing': '<span class="badge badge-warning">Preparing</span>',
                'packed': '<span class="badge badge-purple">Packed</span>',
                'assigned': '<span class="badge badge-info">Rider Assigned</span>',
                'delivered': '<span class="badge badge-success">Delivered</span>',
                'cancelled': '<span class="badge badge-danger">Cancelled</span>'
            };
            return map[status] || '<span class="badge badge-slate">Unknown</span>';
        }

        function renderInventory() {
            const tbody = document.getElementById('inventory-table-body');
            tbody.innerHTML = vendorDB.products.map(p => {
                const isLow = p.stock <= p.minStock;
                return `
                    <tr>
                        <td class="font-semibold">${p.name}</td>
                        <td class="text-muted text-sm">${p.sku}</td>
                        <td>${p.category}</td>
                        <td>
                            <div class="flex items-center gap-2">
                                <div class="w-16 h-2 bg-gray-200 rounded-full overflow-hidden">
                                    <div class="h-full ${isLow ? 'bg-danger' : 'bg-success'}" style="width: ${Math.min(100, (p.stock / (p.minStock * 3)) * 100)}%"></div>
                                </div>
                                <span class="text-sm font-medium ${isLow ? 'text-danger' : ''}">${p.stock}</span>
                            </div>
                        </td>
                        <td>${isLow ? '<span class="badge badge-danger">Low Stock</span>' : '<span class="badge badge-success">In Stock</span>'}</td>
                        <td>
                            <button class="btn btn-sm btn-secondary" onclick="showToast('info', 'Inventory', 'Restock modal opened for ${p.name}')">Restock</button>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        function renderProducts() {
            const grid = document.getElementById('products-grid');
            grid.innerHTML = vendorDB.products.map(p => `
                <div class="card card-hover">
                    <div class="h-32 bg-gray-100 rounded-t-xl flex items-center justify-center text-4xl">
                        ${getCategoryEmoji(p.category)}
                    </div>
                    <div class="p-4">
                        <div class="flex justify-between items-start mb-2">
                            <h4 class="font-bold truncate">${p.name}</h4>
                            <span class="badge badge-slate">${p.category}</span>
                        </div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-lg font-bold text-primary">₹${p.price}</span>
                            <span class="text-sm text-muted">SKU: ${p.sku}</span>
                        </div>
                        <div class="flex gap-2">
                            <button class="btn btn-sm btn-secondary flex-1">Edit</button>
                            <button class="btn btn-sm btn-primary flex-1">View</button>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function renderFinance() {
            const tbody = document.getElementById('finance-table-body');
            tbody.innerHTML = vendorDB.transactions.map(t => `
                <tr>
                    <td class="font-mono text-sm">${t.id}</td>
                    <td class="text-sm text-muted">${t.date}</td>
                    <td>${t.desc}</td>
                    <td>
                        <span class="badge ${t.type === 'credit' ? 'badge-success' : 'badge-danger'}">
                            ${t.type === 'credit' ? 'Credit' : 'Debit'}
                        </span>
                    </td>
                    <td class="font-bold ${t.type === 'credit' ? 'text-success' : 'text-danger'}">
                        ${t.type === 'credit' ? '+' : '-'}₹${t.amount}
                    </td>
                </tr>
            `).join('');
        }

        function getCategoryEmoji(cat) {
            const map = { 'Dairy': '🥛', 'Bakery': '🍞', 'Fruits': '🍎', 'Vegetables': '🍅', 'Beverages': '🥤', 'Snacks': '🍪' };
            return map[cat] || '📦';
        }

        // --- 4. ACTION HANDLERS ---
        function advanceOrder(orderId, newStatus) {
            if (typeof window.advanceOrder === 'function') {
                // Use shared state.js function if available
                // We need to temporarily set currentOrderId for the shared function to work
                window.state.currentOrderId = orderId;
                window.advanceOrder(newStatus);
            } else {
                // Fallback manual state update
                const order = window.state.orders.find(o => o.id === orderId);
                if (order) {
                    order.status = newStatus;
                    window.saveState();
                    showToast('success', 'Order Updated', `Order ${orderId} is now ${newStatus}`);
                }
            }
        }

        // --- 5. ROUTER ---
        const router = {
            navigate: (viewId) => {
                document.querySelectorAll('.view').forEach(el => el.classList.remove('active'));
                document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
                
                const target = document.getElementById(`view-${viewId}`);
                if (target) {
                    target.classList.add('active');
                    document.querySelector(`.nav-item[data-view="${viewId}"]`)?.classList.add('active');
                    
                    const titles = {
                        'dashboard': 'Dashboard',
                        'orders': 'Order Pipeline',
                        'inventory': 'Inventory Management',
                        'products': 'Product Catalog',
                        'analytics': 'Performance Analytics',
                        'finance': 'Financial Overview',
                        'promotions': 'Promotions & Marketing',
                        'team': 'Team Management',
                        'settings': 'Store Settings'
                    };
                    document.getElementById('page-title').textContent = titles[viewId] || 'Dashboard';
                    
                    // Close mobile sidebar if open
                    document.getElementById('sidebar').classList.remove('open');
                }
            }
        };

        // --- 6. TOAST NOTIFICATION SYSTEM ---
        function showToast(type, title, message) {
            const container = document.getElementById('toast-container');
            const icons = {
                'success': '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>',
                'error': '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>',
                'info': '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0284c7" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>'
            };
            
            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.innerHTML = `
                <div class="toast-icon">${icons[type] || icons['info']}</div>
                <div class="toast-content">
                    <div class="toast-title">${title}</div>
                    <div class="toast-message">${message}</div>
                </div>
                <button class="btn-icon" style="padding: 0.25rem;" onclick="this.parentElement.remove()">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            `;
            
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(100%)';
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }

        // --- 7. INITIALIZATION ---
        document.addEventListener('DOMContentLoaded', () => {
            initVendorState();
            
            // Simulate a welcome toast
            setTimeout(() => {
                showToast('info', 'System Ready', 'Vendor panel connected to Local Commerce OS. Open customer.html in another tab to test real-time sync.');
            }, 1000);
        });

        // Expose router globally for inline onclick handlers
        window.router = router;
        window.advanceOrder = advanceOrder;
        window.showToast = showToast;
    </script>
</body>
</html>
