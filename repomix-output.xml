         JAVASCRIPT: ADMIN LOGIC & REAL-TIME SYNC
         ========================================================================== -->
    <script>
        /**
         * LOCAL COMMERCE OS - ADMIN OPERATING SYSTEM CONTROLLER
         * Handles enterprise UI, real-time data sync, and chart rendering.
         */

        // --- 1. STATE SYNCHRONIZATION ---
        function initAdminState() {
            if (!window.state) {
                window.state = JSON.parse(localStorage.getItem('lcos_state')) || {
                    orders: [], stats: { totalOrders: 0, revenue: 0, liveOrders: 0 }, adminMetrics: { gmv: 245000 }
                };
            }

            // Listen for BroadcastChannel messages
            if (typeof window.channel !== 'undefined') {
                window.channel.onmessage = (event) => {
                    window.state = event.data;
                    updateUI(window.state);
                };
            } else {
                // Fallback polling
                setInterval(() => {
                    const stored = JSON.parse(localStorage.getItem('lcos_state'));
                    if (stored && JSON.stringify(stored) !== JSON.stringify(window.state)) {
                        window.state = stored;
                        updateUI(window.state);
                    }
                }, 1000);
            }

            // Initial render
            updateUI(window.state);
            renderRevenueChart();
            renderActivityFeed();
            renderOrdersTable();
        }

        // --- 2. UI UPDATE ENGINE ---
        function updateUI(state) {
            // Update KPIs
            const gmv = state.adminMetrics?.gmv || 245000;
            const liveOrders = state.stats?.liveOrders || 0;
            
            document.getElementById('kpi-gmv').textContent = `₹${gmv.toLocaleString()}`;
            document.getElementById('kpi-live-orders').textContent = liveOrders;
            
            // Update Live Ops counts
            const placed = state.orders.filter(o => o.status === 'placed' || o.status === 'accepted').length;
            const prep = state.orders.filter(o => o.status === 'preparing' || o.status === 'packed').length;
            const delivery = state.orders.filter(o => o.status === 'assigned').length;
            
            document.getElementById('live-count-placed').textContent = placed;
            document.getElementById('live-count-prep').textContent = prep;
            document.getElementById('live-count-delivery').textContent = delivery;
            
            // Update Nav Badge
            const navBadge = document.getElementById('nav-live-badge');
            if (liveOrders > 0) {
                navBadge.textContent = liveOrders;
                navBadge.classList.remove('hidden');
            } else {
                navBadge.classList.add('hidden');
            }

            // Update Live Orders Table
            renderLiveOrdersTable(state);
        }

        function renderLiveOrdersTable(state) {
            const tbody = document.getElementById('live-orders-table');
            const activeOrders = state.orders.filter(o => o.status !== 'delivered' && o.status !== 'cancelled');
            
            if (activeOrders.length === 0) {
                tbody.innerHTML = `<tr><td colspan="8" class="text-center text-muted p-6">No active orders. System is idle.</td></tr>`;
                return;
            }

            tbody.innerHTML = activeOrders.map(o => {
                let statusBadge = '';
                switch(o.status) {
                    case 'placed': statusBadge = '<span class="badge badge-blue">Placed</span>'; break;
                    case 'accepted': statusBadge = '<span class="badge badge-blue">Accepted</span>'; break;
                    case 'preparing': statusBadge = '<span class="badge badge-amber">Preparing</span>'; break;
                    case 'packed': statusBadge = '<span class="badge badge-purple">Packed</span>'; break;
                    case 'assigned': statusBadge = '<span class="badge badge-green">Out for Delivery</span>'; break;
                    default: statusBadge = '<span class="badge badge-gray">Unknown</span>';
                }

                return `
                    <tr>
                        <td class="font-mono font-semibold">${o.id}</td>
                        <td>${o.customer}</td>
                        <td>QuickMart</td>
                        <td>${o.status === 'assigned' ? 'Rahul S. (RID-9876)' : '<span class="text-muted">Pending</span>'}</td>
                        <td>${o.product}</td>
                        <td class="font-semibold">₹${o.price}</td>
                        <td>${statusBadge}</td>
                        <td>${o.status === 'assigned' ? '12 mins' : '--'}</td>
                    </tr>
                `;
            }).join('');
        }

        function renderOrdersTable() {
            const tbody = document.getElementById('orders-table-body');
            // Mock historical data + live state
            const mockOrders = [
                { id: 'ORD-9920', date: 'Today, 09:15 AM', customer: 'Priya Sharma', vendor: 'Fresh Bites', amount: 320, payment: 'UPI', status: 'delivered' },
                { id: 'ORD-9919', date: 'Today, 08:30 AM', customer: 'Amit Patel', vendor: 'MediPlus', amount: 150, payment: 'Card', status: 'delivered' },
                { id: 'ORD-9918', date: 'Yesterday, 06:00 PM', customer: 'Sneha Reddy', vendor: 'QuickMart', amount: 450, payment: 'COD', status: 'delivered' },
            ];

            // Add live orders from state
            const liveOrders = window.state.orders.map(o => ({
                id: o.id,
                date: o.time,
                customer: o.customer,
                vendor: 'QuickMart',
                amount: o.price,
                payment: o.paymentMethod,
                status: o.status
            }));

            const allOrders = [...liveOrders, ...mockOrders];

            tbody.innerHTML = allOrders.map(o => {
                let statusBadge = '';
                switch(o.status) {
                    case 'delivered': statusBadge = '<span class="badge badge-green">Delivered</span>'; break;
                    case 'cancelled': statusBadge = '<span class="badge badge-red">Cancelled</span>'; break;
                    case 'placed': statusBadge = '<span class="badge badge-blue">Placed</span>'; break;
                    case 'preparing': statusBadge = '<span class="badge badge-amber">Preparing</span>'; break;
                    case 'assigned': statusBadge = '<span class="badge badge-purple">Out for Delivery</span>'; break;
                    default: statusBadge = '<span class="badge badge-gray">Processing</span>';
                }

                return `
                    <tr>
                        <td><input type="checkbox"></td>
                        <td class="font-mono font-semibold">${o.id}</td>
                        <td class="text-muted">${o.date}</td>
                        <td>${o.customer}</td>
                        <td>${o.vendor}</td>
                        <td class="font-semibold">₹${o.amount}</td>
                        <td><span class="badge badge-gray">${o.payment}</span></td>
                        <td>${statusBadge}</td>
                        <td>
                            <button class="btn btn-ghost btn-sm">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="1"></circle><circle cx="19" cy="12" r="1"></circle><circle cx="5" cy="12" r="1"></circle></svg>
                            </button>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        // --- 3. CHART RENDERING ---
        function renderRevenueChart() {
            const container = document.getElementById('revenue-chart');
            const data = [45, 52, 38, 65, 72, 58, 80, 92, 75, 88, 95, 110, 105, 125]; // Mock data
            const maxVal = Math.max(...data);
            
            container.innerHTML = data.map((val, i) => {
                const height = (val / maxVal) * 100;
                return `<div class="chart-bar" style="height: ${height}%;" data-value="₹${val}k"></div>`;
            }).join('');
        }

        // --- 4. ACTIVITY FEED ---
        function renderActivityFeed() {
            const feed = document.getElementById('activity-feed');
            const activities = [
                { icon: '🛒', color: 'var(--brand-primary-bg)', text: '<strong>New order</strong> #ORD-9921 placed by Nitish Kumar', time: 'Just now' },
                { icon: '✅', color: 'var(--success-bg)', text: '<strong>Order</strong> #ORD-9920 delivered successfully', time: '5 mins ago' },
                { icon: '🚨', color: 'var(--danger-bg)', text: '<strong>Fraud Alert:</strong> Blocked suspicious login from IP 192.168.x.x', time: '12 mins ago' },
                { icon: '🤖', color: 'var(--purple-bg)', text: '<strong>AI Agent</strong> adjusted surge pricing in Zone 4', time: '15 mins ago' },
                { icon: '💰', color: 'var(--warning-bg)', text: '<strong>Payout</strong> of ₹12,450 processed for QuickMart', time: '1 hour ago' },
            ];

            feed.innerHTML = activities.map(a => `
                <div class="activity-item">
                    <div class="activity-icon" style="background: ${a.color}; font-size: 1rem;">${a.icon}</div>
                    <div class="activity-content">
                        <div class="activity-text">${a.text}</div>
                        <div class="activity-time">${a.time}</div>
                    </div>
                </div>
            `).join('');
        }

        // --- 5. ROUTER ---
        const router = {
            navigate: (viewId) => {
                document.querySelectorAll('.view').forEach(el => el.classList.remove('active'));
                document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
                
                const target = document.getElementById(`view-${viewId}`);
                if (target) {
                    target.classList.add('active');
                    document.querySelector(`.nav-item[data-view="${viewId}"]`)?.classList.add('active');
                    
                    // Re-render tables if switching to those views
                    if (viewId === 'orders') renderOrdersTable();
                    if (viewId === 'live-ops') renderLiveOrdersTable(window.state);
                }
            }
        };

        // --- 6. INITIALIZATION ---
        document.addEventListener('DOMContentLoaded', () => {
            initAdminState();
            window.router = router;
        });
    </script>
</body>
</html>
