        }
        .kpi-card {
            background: var(--bg-primary);
            border: 1px solid var(--border-primary);
            border-radius: var(--radius-lg);
            padding: 1.25rem;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }
        .kpi-header { display: flex; justify-content: space-between; align-items: center; }
        .kpi-label { font-size: 0.8rem; font-weight: 500; color: var(--text-tertiary); }
        .kpi-value { font-size: 1.75rem; font-weight: 700; letter-spacing: -0.02em; }
        .kpi-trend { font-size: 0.75rem; font-weight: 600; display: flex; align-items: center; gap: 4px; }
        .kpi-trend.up { color: var(--success); }
        .kpi-trend.down { color: var(--danger); }

        /* --- 10. Components: Charts (CSS/SVG based) --- */
        .chart-container {
            width: 100%;
            height: 250px;
            position: relative;
            display: flex;
            align-items: flex-end;
            gap: 4px;
            padding: 1rem 0;
        }
        .chart-bar {
            flex: 1;
            background: var(--brand-primary-bg);
            border-radius: 4px 4px 0 0;
            position: relative;
            transition: all var(--transition-base);
            cursor: pointer;
        }
        .chart-bar:hover { background: var(--brand-primary); }
        .chart-bar::after {
            content: attr(data-value);
            position: absolute;
            top: -20px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 0.7rem;
            font-weight: 600;
            color: var(--text-tertiary);
            opacity: 0;
            transition: opacity var(--transition-fast);
        }
        .chart-bar:hover::after { opacity: 1; }

        /* Line Chart Simulation */
        .line-chart {
            width: 100%;
            height: 200px;
            position: relative;
            border-bottom: 1px solid var(--border-primary);
            border-left: 1px solid var(--border-primary);
        }
        .line-chart svg { width: 100%; height: 100%; }

        /* --- 11. Components: Live Map Simulation --- */
        .live-map {
            width: 100%;
            height: 300px;
            background: var(--bg-secondary);
            border-radius: var(--radius-lg);
            position: relative;
            overflow: hidden;
            border: 1px solid var(--border-primary);
        }
        .map-grid {
            width: 100%;
            height: 100%;
            background-image: 
                linear-gradient(rgba(226, 232, 240, 0.5) 1px, transparent 1px),
                linear-gradient(90deg, rgba(226, 232, 240, 0.5) 1px, transparent 1px);
            background-size: 40px 40px;
        }
        .map-pin {
            position: absolute;
            width: 24px;
            height: 24px;
            border-radius: 50% 50% 50% 0;
            transform: translate(-50%, -50%) rotate(-45deg);
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: var(--shadow-md);
            border: 2px solid white;
        }
        .map-pin.store { background: var(--brand-primary); }
        .map-pin.rider { background: var(--success); animation: pulse-pin 2s infinite; }
        .map-pin.customer { background: var(--danger); }
        
        @keyframes pulse-pin {
            0% { box-shadow: 0 0 0 0 rgba(22, 163, 74, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(22, 163, 74, 0); }
            100% { box-shadow: 0 0 0 0 rgba(22, 163, 74, 0); }
        }

        /* --- 12. Components: Activity Feed --- */
        .activity-feed { display: flex; flex-direction: column; }
        .activity-item {
            display: flex;
            gap: 0.75rem;
            padding: 0.75rem 0;
            border-bottom: 1px solid var(--border-secondary);
        }
        .activity-item:last-child { border-bottom: none; }
        .activity-icon {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .activity-content { flex: 1; }
        .activity-text { font-size: 0.875rem; color: var(--text-primary); }
        .activity-text strong { font-weight: 600; }
        .activity-time { font-size: 0.75rem; color: var(--text-tertiary); margin-top: 2px; }

        /* --- 13. Components: AI Center --- */
        .ai-card {
            background: linear-gradient(135deg, #f8fafc 0%, #eff6ff 100%);
            border: 1px solid #bfdbfe;
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            position: relative;
            overflow: hidden;
        }
        .ai-card::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle, rgba(37,99,235,0.1) 0%, transparent 70%);
        }
